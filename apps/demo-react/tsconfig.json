{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@pulse-music/types": ["../../packages/types/src/index.ts"],
      "@pulse-music/core": ["../../packages/core/src/index.ts"],
      "@pulse-music/tokens": ["../../packages/tokens/src/index.ts"],
      "@pulse-music/web-component": ["../../packages/web-component/src/index.ts"],
      "@pulse-music/react": ["../../packages/react/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
