{
  "name": "@pulse-music/core",
  "version": "3.0.0-rc.2",
  "description": "Framework-agnostic audio engine for pulse-player — Web Audio + state machine + typed event bus. Pure TypeScript, no DOM, no framework imports.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@pulse-music/types": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YamadaBlog/pulse-player.git",
    "directory": "packages/core"
  }
}
