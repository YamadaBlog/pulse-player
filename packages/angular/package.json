{
  "name": "@pulse/angular",
  "version": "3.0.0-rc.0",
  "description": "Angular 17+ wrapper for pulse-player. Thin module + Custom Elements registration on top of @pulse/web-component.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@angular/core": ">=17.3.12"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": false
    }
  },
  "dependencies": {
    "@pulse/types": "*",
    "@pulse/web-component": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": true
}
