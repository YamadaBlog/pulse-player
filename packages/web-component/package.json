{
  "name": "@pulse/web-component",
  "version": "0.0.0",
  "description": "Universal Web Component renderer for pulse-player — Lit-based `<pulse-player>` and `<pulse-fab>`. Works in React, Vue, Angular, Svelte, Solid, vanilla JS, or plain HTML.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "dependencies": {
    "@pulse/core": "workspace:*",
    "@pulse/tokens": "workspace:*",
    "@pulse/types": "workspace:*",
    "lit": "^3.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false
}
