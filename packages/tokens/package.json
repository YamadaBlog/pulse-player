{
  "name": "@pulse/tokens",
  "version": "0.0.0",
  "description": "Design tokens for pulse-player — variant gradients, accent colours, animation keyframes, --pulse-scale system. Shared by every web renderer (CSS imports for plain DOM, TS exports for Shadow DOM).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./variants.css": "./src/variants.css",
    "./base.css": "./src/base.css",
    "./animations.css": "./src/animations.css",
    "./styles.css": "./src/index.css"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false
}
