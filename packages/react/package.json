{
  "name": "@pulse-music/react",
  "version": "3.0.0-rc.2",
  "description": "React 18 / 19 wrapper for pulse-player — hooks + JSX components built on @pulse-music/web-component.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@pulse-music/core": "*",
    "@pulse-music/types": "*",
    "@pulse-music/web-component": "*"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YamadaBlog/pulse-player.git",
    "directory": "packages/react"
  }
}
