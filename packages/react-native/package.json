{
  "name": "@pulse/react-native",
  "version": "0.0.0",
  "description": "React Native implementation of pulse-player. Separate renderer (no DOM, no CSS) sharing types + audio engine interface with the web packages.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-native": ">=0.74.0"
  },
  "dependencies": {
    "@pulse/types": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": false
}
