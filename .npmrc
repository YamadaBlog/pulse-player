# Allow ERESOLVE conflicts when installing workspace dependencies.
# Necessary because apps/demo-react-native ships Expo SDK 56 + RN 0.85,
# but react-native-reanimated 4.1's declared peer range tops out at
# RN 0.82. Expo's own installer (`npx expo install`) resolves the
# right versions per SDK; this flag lets the root `npm install`
# succeed without forcing the maintainer to re-run `expo install`
# every time.
legacy-peer-deps=true
